{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Keyloom",
  "version": "0.1.0",
  "identifier": "com.keyloom.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File tests/installer-smoke.ps1 -RuntimeDirectory src-tauri/runtime-bundle/runtime -InstallStatePath src-tauri/runtime-bundle/install-state.json",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Keyloom",
        "width": 1000,
        "height": 700,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "resources": {
      "runtime-bundle/runtime/": "runtime",
      "runtime-bundle/install-state.json": "runtime/install-state.json"
    },
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false,
        "compression": "lzma",
        "startMenuFolder": "Keyloom",
        "installerIcon": "icons/icon.ico",
        "installerHooks": "../installer/nsis/keyloom.nsi"
      }
    }
  }
}
